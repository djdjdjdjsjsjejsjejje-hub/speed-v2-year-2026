Rayfield:Notify({
   Title = "مفتاح التجربة",
   Content = "2026",
   Duration = 5,
   Image = 4483362458,
})

-- 4. إنشاء التبويبات (Tabs)
local MainTab = Window:CreateTab("🏠 الرئيسية", 4483362458) -- تبويب التحكم
local CreditsTab = Window:CreateTab("📜 الحقوق", 4483362458) -- تبويب المطور

-- 5. محتويات التبويب الرئيسي (السرعة والقفز)

-- قسم السرعة
MainTab:CreateSection("⚡ قسم السرعة (Speed)")

local SpeedInput = MainTab:CreateInput({
   Name = "اكتب السرعة المخصصة",
   PlaceholderText = "مثال: 50",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local num = tonumber(Text)
      if num then
         local char = player.Character or player.CharacterAdded:Wait()
         local humanoid = char:FindFirstChildOfClass("Humanoid")
         if humanoid then humanoid.WalkSpeed = num end
      end
   end,
})

MainTab:CreateButton({
   Name = "🚀 تفعيل سرعة خارقة",
   Callback = function()
      local char = player.Character or player.CharacterAdded:Wait()
      local humanoid = char:FindFirstChildOfClass("Humanoid")
      if humanoid then humanoid.WalkSpeed = 250 end
   end,
})

-- قسم القفز
MainTab:CreateSection("🦘 قسم القفز (Jump)")

local JumpInput = MainTab:CreateInput({
   Name = "اكتب قوة القفز المخصصة",
   PlaceholderText = "مثال: 100",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local num = tonumber(Text)
      if num then
         local char = player.Character or player.CharacterAdded:Wait()
         local humanoid = char:FindFirstChildOfClass("Humanoid")
         if humanoid then 
            humanoid.UseJumpPower = true
            humanoid.JumpPower = num 
         end
      end
   end,
})

-- زر إعادة الوضع الطبيعي
MainTab:CreateSection("⚙️ إعادة الضبط")

MainTab:CreateButton({
   Name = "🔄 إعادة السرعة والقفز للطبيعي",
   Callback = function()
      local char = player.Character or player.CharacterAdded:Wait()
      local humanoid = char:FindFirstChildOfClass("Humanoid")
      if humanoid then 
         humanoid.WalkSpeed = 16 
         humanoid.JumpPower = 50
      end
   end,
})

