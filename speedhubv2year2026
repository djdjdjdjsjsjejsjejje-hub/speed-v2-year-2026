        Duration = 4
    })
end

-- 2. تحميل مكتبة Rayfield UI
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- 3. إنشاء النافذة الرئيسية مع نظام المفتاح المدمج
